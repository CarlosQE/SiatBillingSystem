<UserControl x:Class="SiatBillingSystem.Desktop.Views.HistorialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100"
             Loaded="UserControl_Loaded">

    <Grid Background="#1a1a2e">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Título -->
            <RowDefinition Height="Auto"/>   <!-- Filtros -->
            <RowDefinition Height="*"/>      <!-- DataGrid -->
            <RowDefinition Height="Auto"/>   <!-- Barra de totales -->
            <RowDefinition Height="Auto"/>   <!-- Status -->
        </Grid.RowDefinitions>

        <!-- ══ TÍTULO ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#16213e" Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📋" FontSize="22" VerticalAlignment="Center"/>
                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="HISTORIAL DE FACTURAS" FontSize="18"
                               FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Registro del período seleccionado  ·  doble clic o botón PDF para abrir"
                               FontSize="11" Foreground="#6b7280"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ FILTROS ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#0f3460" Padding="16,10">
            <StackPanel Orientation="Horizontal">

                <TextBlock Text="Desde:" Foreground="#94a3b8"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding FechaDesde}"
                            Background="#1a1a2e" Foreground="White" MinWidth="120"/>

                <TextBlock Text="Hasta:" Foreground="#94a3b8"
                           VerticalAlignment="Center" Margin="16,0,8,0"/>
                <DatePicker SelectedDate="{Binding FechaHasta}"
                            Background="#1a1a2e" Foreground="White" MinWidth="120"/>

                <TextBlock Text="NIT/CI:" Foreground="#94a3b8"
                           VerticalAlignment="Center" Margin="16,0,8,0"/>
                <TextBox Text="{Binding FiltroNit, UpdateSourceTrigger=PropertyChanged}"
                         Width="150" Background="#1a1a2e" Foreground="White"
                         BorderBrush="#334155" Padding="8,5"
                         VerticalContentAlignment="Center">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding CargarFacturasCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <!-- Botón buscar -->
                <Button Content="🔍  Buscar" Command="{Binding CargarFacturasCommand}"
                        Margin="12,0,4,0" Padding="14,7" Cursor="Hand"
                        Foreground="White" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#3b82f6"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2563eb"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Accesos rápidos -->
                <Button Content="Hoy" Command="{Binding FiltrarHoyCommand}"
                        Margin="0,0,4,0" Padding="10,7" Cursor="Hand"
                        Background="#374151" Foreground="White" BorderThickness="0"/>

                <Button Content="Este mes" Command="{Binding FiltrarMesActualCommand}"
                        Padding="10,7" Cursor="Hand"
                        Background="#374151" Foreground="White" BorderThickness="0"/>

            </StackPanel>
        </Border>

        <!-- ══ DATAGRID ══════════════════════════════════════════════════════ -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Facturas}"
                  SelectedItem="{Binding FacturaSeleccionada}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeRows="False"
                  SelectionMode="Single"
                  Background="#1a1a2e"
                  RowBackground="#1e1e3a"
                  AlternatingRowBackground="#16213e"
                  BorderThickness="0"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#2d2d4e"
                  HorizontalScrollBarVisibility="Disabled"
                  ColumnHeaderHeight="36"
                  RowHeight="42">

            <!-- Doble clic = abrir PDF -->
            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick"
                              Command="{Binding AbrirPdfCommand}"
                              CommandParameter="{Binding FacturaSeleccionada}"/>
            </DataGrid.InputBindings>

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#0f3460"/>
                    <Setter Property="Foreground" Value="#94a3b8"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10,0"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Setter Property="BorderBrush" Value="#1e293b"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Foreground" Value="#e2e8f0"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="8,0"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1d4ed8"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>

                <!-- N° Factura -->
                <DataGridTextColumn Header="N° FACTURA"
                                    Binding="{Binding NumeroFactura, StringFormat=D8}"
                                    Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="#6ED60E"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Fecha -->
                <DataGridTextColumn Header="FECHA EMISIÓN"
                                    Binding="{Binding FechaEmisionStr}"
                                    Width="140"/>

                <!-- NIT/CI -->
                <DataGridTextColumn Header="NIT / CI"
                                    Binding="{Binding NitCliente}"
                                    Width="110"/>

                <!-- Nombre cliente — Width="*" para tomar el espacio disponible -->
                <DataGridTextColumn Header="CLIENTE / RAZÓN SOCIAL"
                                    Binding="{Binding NombreCliente}"
                                    Width="*" MinWidth="150"/>

                <!-- Monto -->
                <DataGridTextColumn Header="TOTAL (Bs.)"
                                    Binding="{Binding MontoTotal, StringFormat=N2}"
                                    Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="#4ade80"/>
                            <Setter Property="Padding" Value="0,0,8,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Estado con badge de color -->
                <DataGridTemplateColumn Header="ESTADO" Width="135">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="6,3" Margin="4,7"
                                    HorizontalAlignment="Center">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding EstadoColor}"/>
                                </Border.Background>
                                <TextBlock Text="{Binding EstadoBadge}"
                                           Foreground="White" FontSize="11"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- CUF abreviado -->
                <DataGridTextColumn Header="CUF (extracto)"
                                    Binding="{Binding CufCorto}"
                                    Width="180">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Setter Property="Foreground" Value="#64748b"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Botón PDF -->
                <DataGridTemplateColumn Header="PDF" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="📄 Ver"
                                    Command="{Binding DataContext.AbrirPdfCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Background="#374151" Foreground="White"
                                    BorderThickness="0" Padding="6,4"
                                    FontSize="11" Cursor="Hand" Margin="4,6"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- ══ BARRA DE TOTALES ══════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#0f3460" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Barra de progreso cuando está cargando -->
                <ProgressBar Grid.Column="0"
                             IsIndeterminate="{Binding IsCargando}"
                             Height="4" VerticalAlignment="Center"
                             Background="Transparent" Foreground="#3b82f6"
                             BorderThickness="0">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCargando}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>

                <!-- Total facturas -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="Facturas: " Foreground="#94a3b8" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalFacturas}" Foreground="White"
                               FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Pendientes -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="Pend. envío: " Foreground="#94a3b8" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding PendientesEnvio}" Foreground="#f59e0b"
                               FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Monto total -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="Total: " Foreground="#94a3b8" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalMonto, StringFormat='Bs. {0:N2}'}"
                               Foreground="#4ade80" FontWeight="Bold" FontSize="16"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Abrir carpeta -->
                <Button Grid.Column="4" Content="📁 Carpeta PDFs"
                        Command="{Binding AbrirCarpetaFacturasCommand}"
                        Background="#374151" Foreground="White"
                        BorderThickness="0" Padding="10,6" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- ══ STATUS BAR ════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Padding="16,6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#1a1a2e"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                            <Setter Property="Background" Value="#450a0a"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusMessage}" FontSize="12">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#94a3b8"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                <Setter Property="Foreground" Value="#f87171"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

    </Grid>
</UserControl>
