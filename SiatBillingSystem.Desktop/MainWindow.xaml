<Window x:Class="SiatBillingSystem.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SiatBillingSystem.Desktop.ViewModels"
        xmlns:views="clr-namespace:SiatBillingSystem.Desktop.Views"
        Title="Nexus - INSEIN" Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimary}">

    <Window.InputBindings>
        <KeyBinding Key="F1"  Command="{Binding NavigateToPosCommand}"/>
        <KeyBinding Key="F2"  Command="{Binding NavigateToClientesCommand}"/>
        <KeyBinding Key="F3"  Command="{Binding NavigateToHistorialCommand}"/>
        <KeyBinding Key="F10" Command="{Binding NavigateToConfiguracionCommand}"/>
        <KeyBinding Key="B"   Modifiers="Ctrl" Command="{Binding ToggleMenuCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding IsMenuExpanded, Converter={StaticResource MenuWidthConverter}}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="{StaticResource Sidebar}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Logo -->
                <Border DockPanel.Dock="Top" Background="{StaticResource SidebarHeader}" Padding="0,18,0,18">
                    <Grid>
                        <TextBlock Text="NEXUS" HorizontalAlignment="Center"
                                   FontFamily="Segoe UI Black" FontSize="18"
                                   Foreground="{StaticResource Accent}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMenuExpanded}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="N" HorizontalAlignment="Center"
                                   FontFamily="Segoe UI Black" FontSize="22"
                                   Foreground="{StaticResource Accent}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMenuExpanded}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Botón contraer/expandir -->
                <Button DockPanel.Dock="Bottom" Style="{StaticResource NavButton}"
                        Command="{Binding ToggleMenuCommand}" Margin="0,0,0,8">
                    <TextBlock HorizontalAlignment="Center" FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="◀  Contraer"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMenuExpanded}" Value="False">
                                        <Setter Property="Text" Value="▶"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <!-- Botones de navegación -->
                <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">

                    <!-- Facturación F1 -->
                    <Button Command="{Binding NavigateToPosCommand}" ToolTip="Facturación [F1]">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="POS">
                                        <Setter Property="Background" Value="{StaticResource AccentMuted}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                        <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧾" FontSize="15" Width="22" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" Foreground="White" Margin="8,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Facturación  [F1]"/>
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMenuExpanded}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- Clientes F2 -->
                    <Button Command="{Binding NavigateToClientesCommand}" ToolTip="Clientes [F2]">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Clientes">
                                        <Setter Property="Background" Value="{StaticResource AccentMuted}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                        <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" FontSize="15" Width="22" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" Foreground="White" Margin="8,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Clientes  [F2]"/>
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMenuExpanded}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- Historial F3 -->
                    <Button Command="{Binding NavigateToHistorialCommand}" ToolTip="Historial [F3]">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Historial">
                                        <Setter Property="Background" Value="{StaticResource AccentMuted}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                        <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="15" Width="22" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" Foreground="White" Margin="8,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Historial  [F3]"/>
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMenuExpanded}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- Configuración F10 -->
                    <Button Command="{Binding NavigateToConfiguracionCommand}" ToolTip="Configuración [F10]">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Configuracion">
                                        <Setter Property="Background" Value="{StaticResource AccentMuted}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                        <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="15" Width="22" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" Foreground="White" Margin="8,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Configuración  [F10]"/>
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMenuExpanded}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource TopBar}" Padding="20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding CurrentPageTitle}"
                               Foreground="White" FontSize="15" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Background="#1a2a1a" CornerRadius="4"
                            Padding="10,4" VerticalAlignment="Center">
                        <TextBlock Text="● OFFLINE — Contingencia"
                                   Foreground="#4ade80" FontSize="11"
                                   FontFamily="Segoe UI Semibold"/>
                    </Border>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:PosGridViewModel}">
                        <views:PosGridView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ClientesViewModel}">
                        <views:ClientesView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:HistorialViewModel}">
                        <views:HistorialView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ConfiguracionViewModel}">
                        <views:ConfiguracionView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>
    </Grid>
</Window>